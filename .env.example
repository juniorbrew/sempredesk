# =============================================================
# SempreDesk — Variáveis de ambiente (copie para .env e preencha)
# NÃO commitar o .env com valores reais.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=suporte
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=suporte_tecnico

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=suporte
RABBITMQ_DEFAULT_PASS=CHANGE_ME
RABBITMQ_DEFAULT_VHOST=suporte_vhost

# ── Backend (NestJS) — também usados pelo docker-compose ──────
# DB_PASSWORD deve ser igual a POSTGRES_PASSWORD
DB_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
