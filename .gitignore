# =============================================================================
# SempreDesk — .gitignore
# Regra: nada de ambiente local ou credenciais no repositório.
# Modelos versionados: *.example, *.dev.example.yml, .env.example
# =============================================================================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
out/
dist/
build/
**/cache/webpack/

# Logs
logs/
*.log

# Env — NUNCA subir arquivos de ambiente com credenciais
.env
.env.local
.env.production
.env.staging
.env.*.local
# Variantes explícitas de desenvolvimento (.dev.* / .local.*)
.env.dev
.env.development
**/.env.dev
**/.env.development
**/.env.local
# Permitir apenas o exemplo sem segredos
!.env.example

# Claude
.claude/

# System
.DS_Store
Thumbs.db

# Docker
*.pid
# ── Compose local (não versionar) ─────────────────────────────────────────
# docker-compose.override.yml é o nome que o Docker Compose funde automaticamente.
docker-compose.override.yml
docker-compose.dev.yml
docker-compose.local.yml
# ── Infra local (.dev.*) ───────────────────────────────────────────────────
infra/nginx/nginx.dev.conf

# WhatsApp sessions — contém dados de sessão autenticada
backend/whatsapp-sessions/
**/whatsapp-sessions/

# Uploads / arquivos gerados em runtime
backend/uploads/
**/uploads/

# Chaves e certificados
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Audits / backups locais
audits/

# Coverage
coverage/
.nyc_output/

# Relatórios gerados e infra SSL
*.pdf
certbot/
