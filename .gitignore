# =============================================================================
# SempreDesk — .gitignore
# Regra: nada de ambiente local ou credenciais no repositório.
# Modelos versionados: *.example, docker-compose.dev.example.yml, nginx.dev.conf.example
#
# PRODUÇÃO (versionado, imutável salvo decisão explícita do projeto):
#   docker-compose.yml, infra/nginx/nginx.conf
# DESENVOLVIMENTO (cópias locais — NUNCA commitar; alinhado às regras do projeto):
#   • .env, .env.*  (exceto .env.example e backend/.env.example — ver negados abaixo)
#   • docker-compose.override.yml
#   • docker-compose.dev.yml
#   • docker-compose.local.yml
#   • docker-compose.*.local.yml
#   • infra/nginx/nginx.dev.conf
#   • infra/nginx/nginx.local.conf
# =============================================================================

# TypeScript (incremental — gerado localmente)
*.tsbuildinfo

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
out/
dist/
build/
**/cache/webpack/

# Logs
logs/
*.log

# Env — .env e .env.*; exceto .env.example e backend/.env.example (negados em baixo).
.env
.env.*
!.env.example
!backend/.env.example

# Claude
.claude/

# System
.DS_Store
Thumbs.db

# Docker
*.pid
# ── Compose local (ficheiros .dev.* / override — não versionar) ───────────
# override.yml: merge automático com docker compose up (convenção Docker).
docker-compose.override.yml
docker-compose.dev.yml
docker-compose.local.yml
docker-compose.*.local.yml
# ── Nginx local (.dev.* / .local.*) — não versionar ─────────────────────────
infra/nginx/nginx.dev.conf
infra/nginx/nginx.local.conf

# WhatsApp sessions — contém dados de sessão autenticada
backend/whatsapp-sessions/
**/whatsapp-sessions/

# Uploads / arquivos gerados em runtime
backend/uploads/
**/uploads/

# Chaves e certificados
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Audits / backups locais
audits/
backups/
# Arquivos de backup de configuração gerados por scripts
*.bak.*
# Dumps PostgreSQL / DB na raiz (não versionar)
*.dump

# Rascunhos / SQL ad hoc na raiz do repo (máquina local — não versionar)
/hash.txt
/update.sql
/update2.sql

# Coverage
coverage/
.nyc_output/

# Relatórios gerados e infra SSL
*.pdf
certbot/
