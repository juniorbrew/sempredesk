# Copie para .env e ajuste os valores

# App
NODE_ENV=development
PORT=4000
# Domínio base da plataforma — usado para CORS wildcard e resolução de subdomínios multi-tenant
BASE_DOMAIN=sempredesk.com.br
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Etapa 9 — arquivamento / reativação de contatos (omitir ou vazio = habilitado)
# false | 0 | off | no | disabled — desliga arquivo manual, desarquivo manual e reativação automática por WhatsApp
FEATURE_CONTACT_ARCHIVE=

# Database
# Com docker-compose na raiz do repositório, o serviço backend recebe DB_* via environment
# do compose (valores do .env na raiz). Mantenha DB_PASSWORD = POSTGRES_PASSWORD (ver .env.example na raiz).
DB_HOST=localhost
DB_PORT=5432
DB_USER=suporte
DB_PASSWORD=suporte123
DB_NAME=suporte_tecnico
DB_SSL=false

# JWT
JWT_SECRET=altere-em-producao
JWT_REFRESH_SECRET=altere-tambem-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# E-mail inbound (webhook Mailgun/SendGrid/Postmark)
# Se definido, o header x-api-secret deve coincidir
INBOUND_EMAIL_SECRET=

# Portal (URL base para links em e-mails)
PORTAL_URL=http://localhost:3000/portal

# SMTP da plataforma (lembretes de trial SaaS — não usa SMTP por tenant)
# Sem SAAS_SMTP_HOST os lembretes são ignorados (apenas log).
SAAS_SMTP_HOST=
SAAS_SMTP_PORT=587
SAAS_SMTP_USER=
SAAS_SMTP_PASS=
SAAS_SMTP_FROM=
# SAAS_SMTP_SECURE=true
# Desativar job diário: SAAS_TRIAL_REMINDER_ENABLED=false

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=suporte-whatsapp-verify

# Meta App Secret (Painel do app > Configurações > Básico > Segredo do app)
# Valida X-Hub-Signature-256 nos webhooks. Se vazio, a verificação é ignorada (não recomendado em produção).
META_APP_SECRET=
